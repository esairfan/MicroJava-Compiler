 program ArrayMax
  int[] numbers;
  int size;
{
  void main()
    int i, max, val;
  {
    size = 5;
    numbers = new int[size];
    
    // Read 5 numbers from user input
    i = 0;
    while (i < size) {
      read(val);
      numbers[i] = val;
      i = i + 1;
    }
    
    // Find maximum element
    max = numbers[0];
    i = 1;
    while (i < size) {
      if (numbers[i] > max) {
        max = numbers[i];
      }
      i = i + 1;
    }
    
    print(max);
  }
}
